# ───────────────────────────────────────────────
# Database
# ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/nesomn

# ───────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ───────────────────────────────────────────────
# Auth
# ───────────────────────────────────────────────
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-32-byte-min-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# ───────────────────────────────────────────────
# Storage driver: 'local' (dev, simpan ke api/.storage/) atau 'r2' (prod)
# ───────────────────────────────────────────────
STORAGE_DRIVER=local

# ───────────────────────────────────────────────
# Cloudflare R2 / S3 Storage (dipakai saat STORAGE_DRIVER=r2)
# ───────────────────────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nesomn-assets
R2_PUBLIC_URL=

# ───────────────────────────────────────────────
# Email (SMTP)
# ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nesomn.com

# ───────────────────────────────────────────────
# Payment — Pakasir (Indonesia)
# ───────────────────────────────────────────────
PAKASIR_API_KEY=
PAKASIR_WEBHOOK_SECRET=

# ───────────────────────────────────────────────
# Payment — Stripe (Global)
# ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ───────────────────────────────────────────────
# AI Gateway
# ───────────────────────────────────────────────
KIE_AI_API_KEY=

# ───────────────────────────────────────────────
# URLs
# ───────────────────────────────────────────────
CLIENT_URL=http://localhost
API_URL=http://localhost/api
VITE_API_URL=http://localhost/api

# ───────────────────────────────────────────────
# API
# ───────────────────────────────────────────────
PORT=3000

# ───────────────────────────────────────────────
# Seed (akun admin awal)
# ───────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@nesomn.com
SEED_ADMIN_PASSWORD=change-me-strong-password
