{
  "name": "@nesomn/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@nesomn/shared": "workspace:*",
    "elysia": "^1.2.25",
    "@elysiajs/cors": "^1.1.6",
    "drizzle-orm": "^0.38.3",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.30.1"
  }
}
